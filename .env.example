# Copy this file to .env at the repo root and fill in your keys.
# .env is gitignored — never commit your real keys.

# --- fal.ai (PRIMARY — video generation) ---
# Sign up at https://fal.ai → Dashboard → API Keys
# Hosts Seedance 2.0, Kling 3.0, Wan, LTX-Video, etc.
FAL_KEY=

# --- Kling (OPTIONAL backup — direct API, requires deposit) ---
# Only needed if NOT using fal.ai. Sign up at https://app.klingai.com/global/dev
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# --- Pixabay (OPTIONAL — background music) ---
# Free key at https://pixabay.com/api/docs/
PIXABAY_API_KEY=
