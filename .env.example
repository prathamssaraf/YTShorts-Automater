# Copy this file to .env at the repo root and fill in your keys.
# .env is gitignored — never commit your real keys.

# --- Kling (REQUIRED for video generation) ---
# Sign up free at https://app.klingai.com/global/dev
# 66 credits/day refresh; ~6 × 5s clips/day
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# --- Pixabay (OPTIONAL — for background music) ---
# Free key at https://pixabay.com/api/docs/
# Without this, Shorts ship with a silent music track
PIXABAY_API_KEY=
